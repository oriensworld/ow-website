---
import BaseLayout from "@layouts/BaseLayout.astro";
import GridSection from "@components/astro/GridSection.astro";
import ProjectFilter from "@components/react/ProjectFilter";
import { getCollection } from "astro:content";
import { CATEGORY_HIERARCHY, PROJECT_CONTEXTS } from "@lib/constants";

const allProjects = await getCollection("projects");
const projects = allProjects
  .sort((a, b) => a.data.order - b.data.order)
  .map((p) => ({
    id: p.id.replace(/\.mdx?$/, ""),
    title: p.data.title,
    description: p.data.description,
    category: p.data.category,
    context: p.data.context,
    icon: p.data.icon,
    tags: p.data.tags,
    featured: p.data.featured,
    coverImage: p.data.coverImage,
    coverImageGif: p.data.coverImageGif,
  }));

const hierarchy = CATEGORY_HIERARCHY.map((g) => ({
  label: g.label,
  ...(g.children ? { children: [...g.children] } : {}),
}));
---

<BaseLayout title="Projects" description="Selected work across architecture, software, game development, web, and graphic design.">
  <GridSection border="bottom" crosses="bottom" class="pt-10 pb-5">
    <div class="text-center mb-4">
      <h1 class="text-[2.5rem] font-bold tracking-tight">
        Projects
      </h1>
      <p class="text-sm font-normal text-text-secondary mt-2 whitespace-nowrap">
        Our work across architecture, software, game development, web, and graphic design.
      </p>
    </div>
  </GridSection>

  <GridSection class="pb-24 pt-5">
    <ProjectFilter
      client:load
      projects={projects}
      categoryHierarchy={hierarchy}
      contexts={[...PROJECT_CONTEXTS]}
    />
  </GridSection>
</BaseLayout>
