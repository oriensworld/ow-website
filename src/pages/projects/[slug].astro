---
import BaseLayout from "@layouts/BaseLayout.astro";
import GridSection from "@components/astro/GridSection.astro";
import TableOfContents from "@components/astro/TableOfContents.astro";
import { getCollection, render } from "astro:content";
import { formatDate, formatDateFull, readingTime } from "@lib/utils";
import { CATEGORY_COLORS, DEFAULT_CATEGORY_COLOR } from "@lib/constants";

export const prerender = true;

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.id.replace(/\.mdx?$/, "") },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content, headings } = await render(project);
const colors = CATEGORY_COLORS[project.data.category] ?? DEFAULT_CATEGORY_COLOR;
const timeToRead = readingTime(project.body ?? "");

const allProjects = await getCollection("projects");
const currentTags = new Set(project.data.tags);
const related = allProjects
  .filter((p) => p.id !== project.id && p.data.tags.some((t: string) => currentTags.has(t)))
  .sort((a, b) => {
    const aOverlap = a.data.tags.filter((t: string) => currentTags.has(t)).length;
    const bOverlap = b.data.tags.filter((t: string) => currentTags.has(t)).length;
    return bOverlap - aOverlap;
  })
  .slice(0, 3);
---

<BaseLayout title={project.data.title} description={project.data.description}>
  <GridSection border="bottom" crosses="both" class="pt-32 pb-24">
    <div class="relative max-w-[700px] mx-auto">
      {/* Back link */}
      <a
        href="/projects"
        class="inline-flex items-center gap-2 text-sm text-text-secondary hover:text-teal transition-colors no-underline mb-12"
      >
        <span>←</span> Back to Projects
      </a>

      {/* Header */}
      <div class="mb-12">
        <div class="flex flex-wrap items-center gap-x-3 gap-y-1 mb-4">
          <span
            class="font-mono text-[0.65rem] tracking-[0.1em] uppercase"
            style={`color: ${colors.accent}`}
          >
            {project.data.category}
          </span>
          <span class="text-text-tertiary">·</span>
          <span class="font-mono text-[0.65rem] text-text-tertiary">
            Created at {formatDateFull(project.data.date)}
          </span>
          <span class="text-text-tertiary">·</span>
          <span class="font-mono text-[0.65rem] text-text-tertiary">
            Last updated at {formatDateFull(project.data.updatedDate ?? project.data.date)}
          </span>
          <span class="text-text-tertiary">·</span>
          <span class="font-mono text-[0.65rem] text-text-tertiary">
            {timeToRead}
          </span>
        </div>

        <h1 class="text-4xl font-bold tracking-tight mb-4">
          {project.data.title}
        </h1>

        <p class="text-lg font-normal leading-relaxed text-text-secondary">
          {project.data.description}
        </p>

        {/* Tags */}
        <div class="flex gap-2 mt-6 flex-wrap">
          {project.data.tags.map((tag: string) => (
            <span class="font-mono text-[0.65rem] text-text-tertiary bg-bg-card px-3 py-1" style="filter: drop-shadow(0 0 0.5px var(--color-border))" data-squircle="6">
              {tag}
            </span>
          ))}
        </div>

        {/* Links */}
        <div class="flex gap-4 mt-6">
          {project.data.liveUrl && (
            <a
              href={project.data.liveUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-glow text-sm"
            >
              Live Demo ↗
            </a>
          )}
          {project.data.repoUrl && (
            <a
              href={project.data.repoUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-outline text-sm"
            >
              Source Code ↗
            </a>
          )}
        </div>
      </div>

      {/* Cover image */}
      {project.data.coverImage && (
        <div class="mb-12 overflow-hidden" data-squircle="12">
          <img
            src={project.data.coverImage}
            alt={project.data.title}
            class="w-full h-auto"
            loading="eager"
          />
        </div>
      )}

      {/* Divider */}
      <hr class="border-border mb-12" />

      {/* MDX Content + TOC */}
      <div class="relative">
        <div class="prose">
          <Content />
        </div>
        <TableOfContents headings={headings} />
      </div>
    </div>
  </GridSection>

  {/* Related Projects */}
  {related.length > 0 && (
    <GridSection border="top" crosses="top" class="py-16">
      <div class="max-w-[700px] mx-auto">
        <p class="font-mono text-[0.7rem] tracking-[0.15em] uppercase text-text-tertiary mb-8">
          Related Projects
        </p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
          {related.map((r) => {
            const rColors = CATEGORY_COLORS[r.data.category] ?? DEFAULT_CATEGORY_COLOR;
            return (
              <a
                href={`/projects/${r.id.replace(/\.mdx?$/, "")}`}
                class="omnius-card block no-underline group"
              >
                <p
                  class="font-mono text-[0.6rem] tracking-[0.1em] uppercase mb-1"
                  style={`color: ${rColors.accent}`}
                >
                  {r.data.category}
                </p>
                <h3 class="text-sm font-semibold text-text-primary mb-1 group-hover:text-teal transition-colors">
                  {r.data.title}
                </h3>
                <p class="text-xs font-normal text-text-secondary line-clamp-2">
                  {r.data.description}
                </p>
              </a>
            );
          })}
        </div>
      </div>
    </GridSection>
  )}
</BaseLayout>
