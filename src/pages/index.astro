---
import BaseLayout from "@layouts/BaseLayout.astro";
import HeroAnimated from "@components/react/HeroAnimated";
import { getCollection } from "astro:content";

const allProjects = await getCollection("projects");
const heroProjects = allProjects
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 12)
  .map((p) => ({
    title: p.data.title,
    icon: p.data.icon,
    category: p.data.category,
    context: p.data.context,
    tags: p.data.tags?.slice(0, 3) ?? [],
    slug: p.id.replace(/\.mdx?$/, ""),
    coverImage: p.data.coverImage,
    coverImageGif: p.data.coverImageGif,
    featured: p.data.featured,
  }));
---

<BaseLayout title="Home" fullscreen>
  <!-- Hero — full-viewport, unscrollable canvas with floating objects -->
  <div class="hero-viewport">
    <HeroAnimated client:load projects={heroProjects} />
  </div>
</BaseLayout>
